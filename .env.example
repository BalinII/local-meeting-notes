APP_ENV=development
LOG_LEVEL=INFO
APP_NAME=Local Meeting Notes

LMN_DATA_DIR=backend/data
AUDIO_OUTPUT_DIR=backend/data/audio
DATABASE_PATH=backend/data/local_meeting_notes.db
TRANSCRIPT_OUTPUT_DIR=backend/data/transcripts
EXPORT_OUTPUT_DIR=backend/data/exports
TEMP_OUTPUT_DIR=backend/data/tmp
LOG_DIR=backend/data/logs
SESSION_STATE_PATH=backend/data/tmp/mock_session.json
AUDIO_CAPTURE_STATE_PATH=backend/data/tmp/audio_capture_state.json

AUDIO_CHUNK_SECONDS=30
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_CAPTURE_MODE=windows-loopback+microphone
TRANSCRIPTION_PROVIDER=faster-whisper
TRANSCRIPTION_MODEL_SIZE=tiny
TRANSCRIPTION_DEVICE=cpu
DIARIZATION_PROVIDER=librosa-clustering
DIARIZATION_MAX_SPEAKERS=3

MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8765/callback

ENABLE_WINDOWS_LOOPBACK=true
ENABLE_MICROPHONE_CAPTURE=true
ENABLE_DEBUG_PLACEHOLDERS=true
